APP_ENV=development
APP_DEBUG=true

# MySQL / MariaDB - inactive by default
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=viewer_system
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# PostgreSQL - active system database
DB_DRIVER=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=viewer_system
DB_USERNAME=viewer_app
DB_PASSWORD=change-me
DB_CHARSET=utf8

# PostgreSQL admin/provisioning account - only needed for php viewer db:provision
DB_ADMIN_USERNAME=postgres
DB_ADMIN_PASSWORD=

CLIENT_DB_DRIVER=pgsql
CLIENT_DB_HOST=127.0.0.1
CLIENT_DB_PORT=5432
CLIENT_DB_USERNAME=viewer_app
CLIENT_DB_PASSWORD=change-me
CLIENT_DB_CHARSET=utf8
